rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // (Asegúrate de fusionar esto con tus reglas existentes si las tienes en la consola de Firebase)

    match /courses/{courseId} {
      // Tus reglas actuales para cursos
      allow read, write: if request.auth != null;
      
      match /modules/{moduleId} {
        allow read, write: if request.auth != null;
        // La antigua ruta de lecciones anidadas ya no se usa.
      }
    }

    // NUEVAS COLECCIONES RAÍZ (FLAT STRUCTURE)
    match /lecciones/{leccionId} {
      // Validando el ID de referencia al módulo
      allow read: if request.auth != null;
      allow create, update: if request.auth != null 
                            && request.resource.data.keys().hasAll(['courseId', 'moduleId']);
      allow delete: if request.auth != null;
    }

    match /quizzes/{quizId} {
      // Validando el ID de referencia a la lección
      allow read: if request.auth != null;
      allow create, update: if request.auth != null 
                            && request.resource.data.keys().hasAll(['lessonId', 'courseId', 'moduleId']);
      allow delete: if request.auth != null;
    }
  }
}
