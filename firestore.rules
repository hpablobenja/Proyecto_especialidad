rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para obtener el rol del usuario
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Los usuarios no pueden actualizar su propio rol; solo el admin puede hacerlo.
      allow update: if request.auth != null && (request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) 
                    || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
      
      match /modules/{moduleId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && isAdmin();
      }
    }

    match /lecciones/{leccionId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isAdmin()
                            && request.resource.data.keys().hasAll(['courseId', 'moduleId']);
      allow delete: if request.auth != null && isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isAdmin()
                            && request.resource.data.keys().hasAll(['lessonId', 'courseId', 'moduleId']);
      allow delete: if request.auth != null && isAdmin();
    }
  }
}
